

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-email-app-password
SMTP_FROM=your-email@example.com

SECRET_KEY=replace-with-a-long-random-secret
UPLOAD_DIR=uploads

# PostgreSQL is recommended for deployed multi-user usage.
# Works with Supabase, Neon, Render PostgreSQL, or any PostgreSQL host.
# Examples:
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres?sslmode=require
# DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@host:5432/postgres?sslmode=require

# Local SQLite fallback only. Do not use this for production/multiple users.
PHYSIO_DB_PATH=physio.db

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_PHONE=+15551234567

TRANSLATION_PROVIDER=mymemory
# TRANSLATION_API_URL=
# TRANSLATION_API_KEY=
DEV_SHOW_RESET_CODE=false
